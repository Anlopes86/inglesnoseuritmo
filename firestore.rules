rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/students/$(request.auth.uid));
    }

    function currentRole() {
      return signedIn() ? currentUser().data.role : null;
    }

    function isAdmin() {
      return signedIn() && currentRole() == 'admin';
    }

    function isProfessor() {
      return signedIn() && currentRole() == 'professor';
    }

    function isOwnDocument(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function belongsToProfessor() {
      return isProfessor() && resource.data.teacherId == request.auth.uid;
    }

    function belongsToProfessorOnCreate() {
      return isProfessor()
        && request.resource.data.role == 'aluno'
        && request.resource.data.teacherId == request.auth.uid;
    }

    function canManageStudyData(userId) {
      return isOwnDocument(userId)
        || isAdmin()
        || (
          isProfessor()
          && get(/databases/$(database)/documents/students/$(userId)).data.role == 'aluno'
          && get(/databases/$(database)/documents/students/$(userId)).data.teacherId == request.auth.uid
        );
    }

    function validFlashcard() {
      return request.resource.data.f is string
        && request.resource.data.f.size() > 0
        && request.resource.data.f.size() <= 500
        && request.resource.data.b is string
        && request.resource.data.b.size() > 0
        && request.resource.data.b.size() <= 1500
        && request.resource.data.l is string
        && request.resource.data.l.size() <= 200;
    }

    function validRating() {
      return request.resource.data.level in ['hard', 'medium', 'easy'];
    }

    match /students/{userId} {
      allow read: if isAdmin()
        || isOwnDocument(userId)
        || (resource.data.role == 'aluno' && belongsToProfessor());

      allow create: if isAdmin() || belongsToProfessorOnCreate();

      allow update: if isAdmin()
        || (
          resource.data.role == 'aluno'
          && isOwnDocument(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.teacherId == resource.data.teacherId
        )
        || (
          resource.data.role == 'aluno'
          && belongsToProfessor()
          && request.resource.data.role == resource.data.role
          && request.resource.data.teacherId == resource.data.teacherId
        );

      allow delete: if isAdmin()
        || (resource.data.role == 'aluno' && belongsToProfessor());
    }

    match /users/{userId}/myCards/{cardId} {
      allow read, delete: if canManageStudyData(userId);
      allow create, update: if canManageStudyData(userId) && validFlashcard();
    }

    match /users/{userId}/ratings/{ratingId} {
      allow read, delete: if canManageStudyData(userId);
      allow create, update: if canManageStudyData(userId) && validRating();
    }
  }
}
